# .env.example — copy this to .env and fill in your values
# Never commit .env to git.

# Hugging Face token — optional for Qwen2.5-3B (not gated), required for Llama/Mistral
HF_TOKEN=hf_your_token_here

# Comma-separated list of API keys the gateway will accept in the X-API-Key header
API_KEYS=key-dev-123,key-test-456,key-prod-789

# vLLM server address (default: localhost:8000 — only change if vLLM is on a different host)
VLLM_URL=http://localhost:8000

# Gateway rate limit: max requests per minute per IP
RATE_LIMIT_RPM=60

# Gateway listen port
GATEWAY_PORT=8080
